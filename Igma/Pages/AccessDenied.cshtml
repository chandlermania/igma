@page "/access-denied"
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
}
@inject IConfiguration Configuration

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow-sm text-center">
            <div class="card-body py-5">
                <svg class="icon icon-3xl text-danger mb-3 d-block mx-auto"><use href="/lib/coreui-icons/sprites/free.svg#cil-lock-locked"></use></svg>
                <h4 class="mb-2">Access Denied</h4>
                <p class="text-secondary mb-4">
                    Your account doesn't have permission to use this application.<br />
                    Contact your administrator to request access.
                </p>
                @if (!string.IsNullOrWhiteSpace(Configuration["AzureAd:ClientId"]))
                {
                    <a class="btn btn-outline-secondary"
                       asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut">
                        Sign out
                    </a>
                }
            </div>
        </div>
    </div>
</div>
