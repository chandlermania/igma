@page
@{
    ViewData["Title"] = "Access Denied";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-warning shadow-sm">
            <div class="card-header bg-warning text-dark d-flex align-items-center gap-2">
                <svg class="icon"><use href="/lib/coreui-icons/sprites/free.svg#cil-lock-locked"></use></svg>
                <strong>Access Denied</strong>
            </div>
            <div class="card-body">
                <p class="mb-2">Your account is not assigned to a role in this application.</p>
                <p class="text-secondary small mb-0">
                    Ask an administrator to assign you the <strong>Reader</strong> or <strong>Writer</strong> role
                    in the Azure App Registration, then sign out and back in.
                </p>
            </div>
            <div class="card-footer d-flex gap-2">
                <a href="/MicrosoftIdentity/Account/SignOut" class="btn btn-sm btn-outline-secondary">Sign out</a>
            </div>
        </div>
    </div>
</div>
