@page "/ip-groups/{id:int}"
@model IpGroupModel
@{
    ViewData["Title"] = Model.GroupName ?? "IP Group";
}

@if (Model.Error is not null)
{
    <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
        <svg class="icon flex-shrink-0"><use href="/lib/coreui-icons/sprites/free.svg#cil-warning"></use></svg>
        <div>@Model.Error</div>
    </div>
}

@if (Model.SuccessMessage is not null)
{
    <div class="alert alert-success alert-dismissible d-flex align-items-center gap-2" role="alert">
        <svg class="icon flex-shrink-0"><use href="/lib/coreui-icons/sprites/free.svg#cil-check-circle"></use></svg>
        <div>@Model.SuccessMessage</div>
        <button type="button" class="btn-close ms-auto" data-coreui-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header d-flex align-items-center gap-2 flex-wrap">
        <svg class="icon"><use href="/lib/coreui-icons/sprites/free.svg#cil-layers"></use></svg>
        <div class="flex-grow-1">
            <strong>@Model.GroupName</strong>
            <div class="text-secondary" style="font-size: 0.8rem; font-weight: normal;">
                <span title="@Model.SubscriptionId">@Model.SubscriptionName</span>
                &bull; @Model.ResourceGroup
                &bull; @Model.TotalCount entries
            </div>
        </div>
        <div class="d-flex align-items-center gap-2 ms-auto">
            <button class="btn btn-sm btn-outline-secondary"
                    data-coreui-toggle="modal"
                    data-coreui-target="#descriptionModal"
                    title="Edit description">
                <svg class="icon icon-sm me-1"><use href="/lib/coreui-icons/sprites/free.svg#cil-pencil"></use></svg>
                @(string.IsNullOrWhiteSpace(Model.GroupDescription) ? "Add description" : "Edit description")
            </button>
            @if (Model.UnlabeledCount > 0)
            {
                <span class="badge text-bg-warning fs-6">@Model.UnlabeledCount unlabeled</span>
            }
            else
            {
                <span class="badge text-bg-success fs-6">All labeled</span>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.GroupDescription))
    {
        <div class="card-body border-bottom py-2 px-3 text-body-secondary">
            @Model.GroupDescription
        </div>
    }

    <table class="table table-hover table-striped table-sm mb-0">
        <thead class="table-dark">
            <tr>
                <th>IP / CIDR</th>
                <th>Label</th>
                <th>Notes</th>
                <th>Last Updated</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var entry in Model.Entries)
            {
                <tr>
                    <td class="font-monospace align-middle">@entry.IpAddress</td>
                    <td class="align-middle">
                        @if (entry.IsLabeled)
                        {
                            <span class="fw-medium">@entry.Label</span>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">
                                <svg class="icon icon-sm me-1"><use href="/lib/coreui-icons/sprites/free.svg#cil-warning"></use></svg>
                                Unlabeled
                            </span>
                        }
                    </td>
                    <td class="align-middle text-secondary small"><span class="notes-cell">@entry.Notes</span></td>
                    <td class="align-middle text-secondary small">
                        @entry.LabeledAt?.ToString("yyyy-MM-dd HH:mm")
                        @if (entry.LabeledBy is not null)
                        {
                            <div style="font-size:0.75em">@entry.LabeledBy</div>
                        }
                    </td>
                    <td class="text-end align-middle">
                        <button class="btn btn-sm btn-primary"
                                data-coreui-toggle="modal"
                                data-coreui-target="#editModal"
                                data-ip="@entry.IpAddress"
                                data-label="@entry.Label"
                                data-notes="@entry.Notes">
                            <svg class="icon icon-sm me-1"><use href="/lib/coreui-icons/sprites/free.svg#cil-pencil"></use></svg>
                            Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-secondary">Showing @Model.PageStart–@Model.PageEnd of @Model.TotalCount</small>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-page="/IpGroup" asp-route-id="@Model.GroupDbId" asp-route-page="@(Model.CurrentPage - 1)">&#8249;</a>
                    </li>
                    @{
                        int pStart = Math.Max(1, Model.CurrentPage - 3);
                        int pEnd   = Math.Min(Model.TotalPages, Model.CurrentPage + 3);
                    }
                    @if (pStart > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-page="/IpGroup" asp-route-id="@Model.GroupDbId" asp-route-page="1">1</a>
                        </li>
                        @if (pStart > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }
                    @for (int p = pStart; p <= pEnd; p++)
                    {
                        <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-page="/IpGroup" asp-route-id="@Model.GroupDbId" asp-route-page="@p">@p</a>
                        </li>
                    }
                    @if (pEnd < Model.TotalPages)
                    {
                        @if (pEnd < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" asp-page="/IpGroup" asp-route-id="@Model.GroupDbId" asp-route-page="@Model.TotalPages">@Model.TotalPages</a>
                        </li>
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-page="/IpGroup" asp-route-id="@Model.GroupDbId" asp-route-page="@(Model.CurrentPage + 1)">&#8250;</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="saveToast" class="toast align-items-center border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body fw-medium" id="saveToastBody"></div>
            <button type="button" class="btn-close me-2 m-auto" data-coreui-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<!-- Edit Description Modal -->
<div class="modal fade" id="descriptionModal" tabindex="-1" aria-labelledby="descriptionModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form id="descriptionForm" method="post" asp-page-handler="SaveDescriptionJson">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title d-flex align-items-center gap-2" id="descriptionModalLabel">
                        <svg class="icon"><use href="/lib/coreui-icons/sprites/free.svg#cil-description"></use></svg>
                        Group Description
                    </h5>
                    <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="descriptionInput" class="form-label">Description</label>
                        <textarea class="form-control" id="descriptionInput" name="description" rows="4"
                                  placeholder="Optional description for this IP Group" maxlength="500">@Model.GroupDescription</textarea>
                        <div class="form-text text-end"><span id="descCharCount">@(Model.GroupDescription?.Length ?? 0)</span>/500</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <svg class="icon icon-sm me-1"><use href="/lib/coreui-icons/sprites/free.svg#cil-save"></use></svg>
                        Save
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Edit Label Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="SaveLabelJson">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title d-flex align-items-center gap-2" id="editModalLabel">
                        <svg class="icon"><use href="/lib/coreui-icons/sprites/free.svg#cil-tag"></use></svg>
                        Edit Label
                    </h5>
                    <button type="button" class="btn-close" data-coreui-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="ipAddress" id="modalIpAddress" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">IP / CIDR</label>
                        <p class="font-monospace mb-0" id="modalIpDisplay"></p>
                        <small class="text-secondary">Label applies to this IP/CIDR across all groups.</small>
                    </div>
                    <div class="mb-3">
                        <label for="modalLabel" class="form-label">Label</label>
                        <input type="text" class="form-control" id="modalLabel" name="label"
                               placeholder="e.g. Corp VPN, Office NAT" maxlength="200" />
                    </div>
                    <div class="mb-3">
                        <label for="modalNotes" class="form-label">Notes</label>
                        <textarea class="form-control" id="modalNotes" name="notes" rows="3"
                                  placeholder="Optional additional context" maxlength="300"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-coreui-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <svg class="icon icon-sm me-1"><use href="/lib/coreui-icons/sprites/free.svg#cil-save"></use></svg>
                        Save
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Description modal
        const descriptionInput = document.getElementById('descriptionInput');
        const descCharCount = document.getElementById('descCharCount');
        descriptionInput.addEventListener('input', () => {
            descCharCount.textContent = descriptionInput.value.length;
        });

        const descriptionForm = document.getElementById('descriptionForm');
        descriptionForm.addEventListener('submit', async function (e) {
            e.preventDefault();
            const saveBtn = descriptionForm.querySelector('[type=submit]');
            saveBtn.disabled = true;

            try {
                const response = await fetch('?handler=SaveDescriptionJson', {
                    method: 'POST',
                    body: new FormData(descriptionForm)
                });
                const result = await response.json();
                if (result.success) {
                    sessionStorage.setItem('igma.toast', 'Description saved.');
                    window.location.reload();
                } else {
                    showToast(result.error || 'Failed to save description. Please try again.', false);
                    saveBtn.disabled = false;
                }
            } catch {
                showToast('Failed to save description. Please try again.', false);
                saveBtn.disabled = false;
            }
        });

        // Label modal
        const editModal = document.getElementById('editModal');
        const editForm = editModal.querySelector('form');
        const saveToastEl = document.getElementById('saveToast');
        const saveToast = new coreui.Toast(saveToastEl, { delay: 4000 });

        function showToast(message, success) {
            saveToastEl.classList.toggle('text-bg-success', success);
            saveToastEl.classList.toggle('text-bg-danger', !success);
            document.getElementById('saveToastBody').textContent = message;
            saveToast.show();
        }

        const pendingToast = sessionStorage.getItem('igma.toast');
        if (pendingToast) {
            sessionStorage.removeItem('igma.toast');
            showToast(pendingToast, true);
        }

        editModal.addEventListener('show.coreui.modal', function (event) {
            const btn = event.relatedTarget;
            document.getElementById('modalIpAddress').value = btn.dataset.ip;
            document.getElementById('modalIpDisplay').textContent = btn.dataset.ip;
            document.getElementById('modalLabel').value = btn.dataset.label || '';
            document.getElementById('modalNotes').value = btn.dataset.notes || '';
        });

        editForm.addEventListener('submit', async function (e) {
            e.preventDefault();
            const saveBtn = editForm.querySelector('[type=submit]');
            saveBtn.disabled = true;

            try {
                const response = await fetch('?handler=SaveLabelJson', {
                    method: 'POST',
                    body: new FormData(editForm)
                });
                const result = await response.json();
                if (result.success) {
                    const ip = document.getElementById('modalIpAddress').value;
                    sessionStorage.setItem('igma.toast', `Label saved for ${ip}.`);
                    window.location.reload();
                } else {
                    showToast(result.error || 'Failed to save label. Please try again.', false);
                    saveBtn.disabled = false;
                }
            } catch {
                showToast('Failed to save label. Please try again.', false);
                saveBtn.disabled = false;
            }
        });
    </script>
}
